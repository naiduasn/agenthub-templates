{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenthub.dev/schemas/connection-template.schema.json",
  "type": "object",
  "required": ["kind", "id", "name", "version", "status", "connectionKind", "capabilities"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "connection" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "enum": ["active", "draft", "deprecated"] },
    "connectionKind": { "enum": ["mcp", "api", "database", "file", "custom"] },
    "auth": { "type": "string" },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
