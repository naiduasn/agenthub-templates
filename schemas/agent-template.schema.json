{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenthub.dev/schemas/agent-template.schema.json",
  "type": "object",
  "required": ["kind", "id", "name", "version", "status", "description", "template", "instructionsFile"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "agent" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "enum": ["draft", "published", "deprecated"] },
    "description": { "type": "string", "minLength": 1 },
    "template": { "type": "string", "minLength": 1 },
    "instructionsFile": { "type": "string", "minLength": 1 },
    "requiredSkills": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "requiredConnections": {
      "type": "array",
      "items": { "$ref": "#/$defs/connectionSlot" }
    },
    "config": { "type": "object" }
  },
  "$defs": {
    "connectionSlot": {
      "type": "object",
      "required": ["slot", "capabilities"],
      "additionalProperties": true,
      "properties": {
        "slot": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "label": { "type": "string" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}
